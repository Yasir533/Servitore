<UserControl x:Class="Servitore.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Servitore.Desktop">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             Dark Sidebar Navigation
        ════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource ServitoreSidebarBrush}">
            <DockPanel>

                <!-- Brand header -->
                <Border DockPanel.Dock="Top"
                        Padding="20,24,20,20"
                        BorderBrush="#2C3E50"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="SERVITORE"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Text="Service Management"
                                   FontSize="10"
                                   Opacity="0.45"
                                   Foreground="White"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Border>

                <!-- Nav buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">

                    <Button Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="Customers">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Customers" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="Products">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Devices" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Products" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="ServiceEntries">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TicketOutline" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Service Entries" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>



                    <!-- Separator -->
                    <Separator Background="#2C3E50" Margin="20,8" />

                    <Button Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="Reports">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Reports" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="UsersBtn" Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="Users">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCog" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Users" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ActivityLogsBtn" Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="ActivityLogs">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewList" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Activity Logs" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="LiveUsersBtn" Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="LiveUsers">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Live Users" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="SettingsBtn" Style="{StaticResource SidebarNavButton}"
                            Click="NavButton_Click" Tag="Settings">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,14,0" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Header Bar -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource MaterialDesignPaper}"
                    Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Global Search (styled input with autocomplete) -->
                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <TextBox materialDesign:HintAssist.Hint="Global search..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 x:Name="GlobalSearchBox"
                                 TextChanged="GlobalSearchBox_TextChanged"
                                 KeyDown="GlobalSearchBox_KeyDown" />
                        <Popup x:Name="SearchAutocompletePopup"
                               StaysOpen="False"
                               PlacementTarget="{Binding ElementName=GlobalSearchBox}"
                               Placement="Bottom"
                               Width="300"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    MaxHeight="350"
                                    Padding="8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="SearchResultsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                        HorizontalContentAlignment="Left"
                                                        Click="SearchResult_Click"
                                                        Margin="0,2"
                                                        Padding="8,4">
                                                    <Grid HorizontalAlignment="Stretch" Width="260">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" FontSize="12" />
                                                            <TextBlock Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis" Opacity="0.6" FontSize="10" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding Type}" Opacity="0.5" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- User Profile & Notifications -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        
                        <!-- Notification Button -->
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                x:Name="NotificationBtn"
                                Click="NotificationBtn_Click"
                                ToolTip="Notification Center"
                                Margin="0,0,16,0">
                            <Grid>
                                <materialDesign:PackIcon Kind="Bell" Width="20" Height="20" />
                                <!-- Badge indicator (red dot) -->
                                <Border Background="Red" CornerRadius="4" Width="8" Height="8" 
                                        HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Margin="0,-2,-2,0" 
                                        Visibility="{Binding HasNoNotifications, Converter={StaticResource InverseBooleanConverter}}" />
                            </Grid>
                        </Button>

                        <!-- Notification Popup -->
                        <Popup x:Name="NotificationPopup" StaysOpen="False" PlacementTarget="{Binding ElementName=NotificationBtn}" Placement="Bottom">
                            <Border Background="{DynamicResource MaterialDesignPaper}" 
                                    BorderBrush="{DynamicResource MaterialDesignDivider}" 
                                    BorderThickness="1" CornerRadius="4" Width="320" MaxHeight="400" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Notification Center" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" />
                                    <Separator Margin="0,0,0,12" />
                                    
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                        <ItemsControl ItemsSource="{Binding Summary.RecentNotifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="0,8">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" />
                                                            <TextBlock Grid.Row="1" Text="{Binding CreatedDate, StringFormat='{}{0:dd MMM HH:mm}'}" 
                                                                       Opacity="0.5" FontSize="10" Margin="0,4,0,0" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    
                                    <TextBlock Text="No new notifications." Opacity="0.5" FontSize="12" HorizontalAlignment="Center" Margin="0,16,0,0"
                                               Visibility="{Binding HasNoNotifications, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </Popup>

                        <!-- Logged-in User Info -->
                        <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="{Binding Source={x:Static local:App.AuthenticationService}, Path=CurrentUser.FullName, FallbackValue='John Doe'}"
                                       FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding Source={x:Static local:App.AuthenticationService}, Path=CurrentUser.Role, FallbackValue='Operator'}"
                                       Opacity="0.55" FontSize="10" HorizontalAlignment="Right" />
                        </StackPanel>
                        
                        <!-- Avatar Icon -->
                        <materialDesign:PackIcon Kind="AccountCircle" Width="32" Height="32" VerticalAlignment="Center" Opacity="0.75" />

                        <!-- Status Selector Combo -->
                        <ComboBox x:Name="StatusSelectorCombo"
                                  Width="105"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  materialDesign:TextFieldAssist.HasClearButton="False"
                                  SelectionChanged="StatusSelectorCombo_SelectionChanged">
                            <ComboBoxItem Tag="Online">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Online" FontSize="12"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="Away">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#FF9800" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Away" FontSize="12"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="Busy">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#F44336" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Busy" FontSize="12"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="Offline">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#9E9E9E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Offline" FontSize="12"/>
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area Host -->
            <ContentControl x:Name="ContentHost" Grid.Row="1" />

            <!-- Toast Notification Area -->
            <materialDesign:Snackbar x:Name="MainSnackbar" Grid.Row="1"
                                     MessageQueue="{materialDesign:MessageQueue}"
                                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                     Margin="24,0,0,24" />
        </Grid>
    </Grid>
</UserControl>
