<UserControl x:Class="Servitore.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="System Settings" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Application configuration" Opacity="0.55" FontSize="13" Margin="0,0,0,24" />

            <!-- Company Info -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Company Information" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Company Name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="0" Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Phone"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Grid.Row="2" Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Email"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Website"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CompanyWebsite, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                 materialDesign:HintAssist.Hint="Address"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SMTP Settings -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Email (SMTP) Settings" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0" Grid.Column="0"
                                 materialDesign:HintAssist.Hint="SMTP Host"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding SmtpHost}" />
                        <TextBox Grid.Row="0" Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Port"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding SmtpPort}" />
                        <TextBox Grid.Row="2" Grid.Column="0"
                                 materialDesign:HintAssist.Hint="From Address"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding SmtpFromAddress}" />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 materialDesign:HintAssist.Hint="From Name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding SmtpFromName}" />
                        <TextBox Grid.Row="4" Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Username"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding SmtpUsername}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- WhatsApp Configuration -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6"
                    Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="WhatsApp Configuration" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Company Phone Number (WhatsApp Receiver)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding WaPhoneNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Grid.Row="0" Grid.Column="2"
                                 materialDesign:HintAssist.Hint="API Key / Token"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding WaApiKey, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                  Content="Enable WhatsApp Notifications"
                                  Style="{StaticResource MaterialDesignActionLightCheckBox}"
                                  IsChecked="{Binding WaIsEnabled, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Ticket Format -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6"
                    Padding="24" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Ticket Number Format" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <TextBox materialDesign:HintAssist.Hint="e.g. TKT-{YYYY}-{0000}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding TicketNumberFormat}" />
                    <TextBlock Text="Tokens: {YYYY} = year, {MM} = month, {0000} = auto-increment"
                               Opacity="0.5" FontSize="11" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Button Content="Save Settings"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
