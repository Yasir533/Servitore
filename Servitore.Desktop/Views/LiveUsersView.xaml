<UserControl x:Class="Servitore.Desktop.Views.LiveUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Live Connected Users" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Text="Real-time multi-user collaboration presence monitor" Opacity="0.55" FontSize="13" />
            </StackPanel>

            <Button Grid.Column="1" x:Name="BroadcastBtn" Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                    Click="BroadcastBtn_Click" VerticalAlignment="Center" Height="40">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="BullhornOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Broadcast Message" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- KPI Metrics Row -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,0,0,20">
            <!-- Total Connected -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Margin="0,0,12,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Total Connected" Opacity="0.6" FontSize="11" />
                    <TextBlock x:Name="TotalUsersText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" Foreground="#2196F3" />
                </StackPanel>
            </Border>

            <!-- Active Users -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Margin="0,0,12,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Active Users (Online/Busy)" Opacity="0.6" FontSize="11" />
                    <TextBlock x:Name="ActiveUsersText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" Foreground="#4CAF50" />
                </StackPanel>
            </Border>

            <!-- Idle Users -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Idle Users (Away)" Opacity="0.6" FontSize="11" />
                    <TextBlock x:Name="IdleUsersText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" Foreground="#FF9800" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Data Grid -->
        <Border Grid.Row="2" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Padding="12">
            <DataGrid x:Name="UsersDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      materialDesign:DataGridAssist.CellPadding="12 8 12 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="12 8 12 8">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Status" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Colored status dot -->
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Online">
                                                        <Setter Property="Fill" Value="#4CAF50" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Away">
                                                        <Setter Property="Fill" Value="#FF9800" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Busy">
                                                        <Setter Property="Fill" Value="#F44336" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Offline">
                                                        <Setter Property="Fill" Value="#9E9E9E" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" FontWeight="Medium" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="110" FontWeight="SemiBold" />
                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100" />
                    <DataGridTextColumn Header="Active Module" Binding="{Binding CurrentModule}" Width="*" />
                    <DataGridTextColumn Header="Computer Name" Binding="{Binding ComputerName}" Width="130" />
                    <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="120" />
                    <DataGridTextColumn Header="Login Time" Binding="{Binding LoginTime, StringFormat='{}{0:dd MMM HH:mm:ss}'}" Width="140" />
                    <DataGridTextColumn Header="Last Activity" Binding="{Binding LastActivity, StringFormat='{}{0:HH:mm:ss}'}" Width="110" />
                    <DataGridTextColumn x:Name="AppVersionColumn" Header="App Version" Binding="{Binding AppVersion}" Width="125" />
                    <DataGridTextColumn x:Name="EditingRecordColumn" Header="Editing Record" Binding="{Binding EditingRecord}" Width="130" />
                    <DataGridTemplateColumn x:Name="ActionsColumn" Header="Actions" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Session Details" Width="30" Height="30"
                                            Click="SessionDetails_Click">
                                        <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Force Logout User" Width="30" Height="30"
                                            Foreground="#F44336"
                                            Click="ForceLogout_Click">
                                        <materialDesign:PackIcon Kind="Logout" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
