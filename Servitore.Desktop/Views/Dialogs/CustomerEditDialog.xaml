<Window x:Class="Servitore.Desktop.Views.Dialogs.CustomerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Customer Details" Height="580" Width="440"
        Icon="pack://application:,,,/Assets/Icons/logo.ico"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        FontSize="14.5"
        FocusManager.FocusedElement="{Binding ElementName=NameBox}"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Edit Customer" FontSize="20" FontWeight="SemiBold" x:Name="TitleText" />
            <TextBlock Text="Fill out the details below. Required fields are marked with (*)." FontSize="12" Opacity="0.6" Margin="0,2,0,12" />
            
            <!-- Inline validation error banner -->
            <Border x:Name="ErrorBanner" Background="#FFEBEE" BorderBrush="#EF5350" BorderThickness="1" CornerRadius="4" Padding="10" Visibility="Collapsed" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="#E53935" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="ErrorBannerText" Foreground="#C62828" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                <TextBox x:Name="NameBox"
                         materialDesign:HintAssist.Hint="Customer Name *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="Input_Changed"
                         Margin="0,0,0,12" />

                <TextBox x:Name="CompanyBox"
                         materialDesign:HintAssist.Hint="Company"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="Input_Changed"
                         Margin="0,0,0,12" />

                <TextBox x:Name="MobileBox"
                         materialDesign:HintAssist.Hint="Mobile *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="Input_Changed"
                         Margin="0,0,0,12" />

                <TextBox x:Name="EmailBox"
                         materialDesign:HintAssist.Hint="Email"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="Input_Changed"
                         Margin="0,0,0,12" />

                <TextBox x:Name="AddressBox"
                         materialDesign:HintAssist.Hint="Address"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="Input_Changed"
                         Margin="0,0,0,12" />

                <TextBox x:Name="NotesBox"
                         materialDesign:HintAssist.Hint="Notes"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="75" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="Input_Changed" />
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons Panel -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="Reset" Style="{StaticResource MaterialDesignFlatButton}" Click="Reset_Click" Margin="0,0,8,0" />
                <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}" Click="Cancel_Click" />
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button x:Name="SaveNewButton" Content="Save &amp; New" Style="{StaticResource MaterialDesignOutlinedButton}" Click="SaveNew_Click" Margin="0,0,8,0" ToolTip="Ctrl+N" />
                <Button x:Name="SaveButton" Content="Save &amp; Close" Style="{StaticResource MaterialDesignRaisedButton}" Click="SaveClose_Click" Width="120" ToolTip="Ctrl+S" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
