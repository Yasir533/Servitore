<Window x:Class="Servitore.Desktop.Views.Dialogs.CustomerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Customer Details" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Edit Customer" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" x:Name="TitleText"/>

        <StackPanel Grid.Row="1">
            <TextBox x:Name="NameBox"
                     materialDesign:HintAssist.Hint="Customer Name *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,12" />

            <TextBox x:Name="ContactBox"
                     materialDesign:HintAssist.Hint="Contact Person"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,12" />

            <TextBox x:Name="MobileBox"
                     materialDesign:HintAssist.Hint="Mobile"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,12" />

            <TextBox x:Name="EmailBox"
                     materialDesign:HintAssist.Hint="Email"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,12" />

            <TextBox x:Name="AddressBox"
                     materialDesign:HintAssist.Hint="Address"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button Content="Save" Style="{StaticResource MaterialDesignRaisedButton}" Click="Save_Click" Width="90" />
        </StackPanel>
    </Grid>
</Window>
