<Window x:Class="Servitore.Desktop.Views.Dialogs.AssetEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Asset Details" Height="500" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Loaded="Window_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Edit Asset" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" x:Name="TitleText"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                <TextBox x:Name="ProductNameBox"
                         materialDesign:HintAssist.Hint="Product Name *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <TextBox x:Name="AssetCodeBox"
                         materialDesign:HintAssist.Hint="Asset Code *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <TextBox x:Name="SerialNumberBox"
                         materialDesign:HintAssist.Hint="Serial Number"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <ComboBox x:Name="CustomerCombo"
                          materialDesign:HintAssist.Hint="Assign Customer *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="CustomerName"
                          SelectedValuePath="CustomerId"
                          Margin="0,0,0,12" />

                <ComboBox x:Name="StatusCombo"
                          materialDesign:HintAssist.Hint="Status *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,12">
                    <ComboBoxItem Content="Active" Tag="Active" IsSelected="True" />
                    <ComboBoxItem Content="Inactive" Tag="Inactive" />
                    <ComboBoxItem Content="Scrapped" Tag="Scrapped" />
                    <ComboBoxItem Content="Retired" Tag="Retired" />
                </ComboBox>

                <TextBox x:Name="VendorNameBox"
                         materialDesign:HintAssist.Hint="Vendor Name"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <DatePicker x:Name="PurchaseDatePicker"
                            materialDesign:HintAssist.Hint="Purchase Date"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,0,12" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button Content="Save" Style="{StaticResource MaterialDesignRaisedButton}" Click="Save_Click" Width="90" />
        </StackPanel>
    </Grid>
</Window>
