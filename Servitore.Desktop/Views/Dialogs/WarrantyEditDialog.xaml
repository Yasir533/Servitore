<Window x:Class="Servitore.Desktop.Views.Dialogs.WarrantyEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Warranty Details" Height="480" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Loaded="Window_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Edit Warranty" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" x:Name="TitleText"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                <ComboBox x:Name="CustomerCombo"
                          materialDesign:HintAssist.Hint="Customer *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="CustomerName"
                          SelectedValuePath="CustomerId"
                          SelectionChanged="CustomerCombo_SelectionChanged"
                          Margin="0,0,0,12" />

                <ComboBox x:Name="AssetCombo"
                          materialDesign:HintAssist.Hint="Asset Product *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="ProductName"
                          SelectedValuePath="AssetId"
                          Margin="0,0,0,12" />

                <DatePicker x:Name="StartDatePicker"
                            materialDesign:HintAssist.Hint="Start Date *"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,0,12" />

                <DatePicker x:Name="EndDatePicker"
                            materialDesign:HintAssist.Hint="End Date *"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,0,12" />

                <TextBox x:Name="VendorBox"
                         materialDesign:HintAssist.Hint="Vendor Name"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <TextBox x:Name="TermsBox"
                         materialDesign:HintAssist.Hint="Warranty Terms"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button Content="Save" Style="{StaticResource MaterialDesignRaisedButton}" Click="Save_Click" Width="90" />
        </StackPanel>
    </Grid>
</Window>
