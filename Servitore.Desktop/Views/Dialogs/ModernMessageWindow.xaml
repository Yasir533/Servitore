<Window x:Class="Servitore.Desktop.Views.Dialogs.ModernMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Servitore" Height="220" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        FontSize="14.5">

    <Border Background="{DynamicResource MaterialDesignPaper}" 
            BorderBrush="{DynamicResource MaterialDesignDivider}" 
            BorderThickness="1" 
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="15" ShadowDepth="3" Direction="270" />
        </Border.Effect>
        
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header / Title -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon x:Name="MsgIcon" Kind="Information" Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" x:Name="TitleText" Text="Message" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </Grid>

            <!-- Message Text -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <TextBlock x:Name="MessageText" Text="Message Content Goes Here." TextWrapping="Wrap" FontSize="14" Opacity="0.85" VerticalAlignment="Center" />
            </ScrollViewer>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0" Click="BtnCancel_Click" Visibility="Collapsed" IsCancel="True" />
                <Button x:Name="BtnNo" Content="No" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0" Click="BtnNo_Click" Visibility="Collapsed" IsCancel="True" />
                <Button x:Name="BtnDiscard" Content="Discard" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0" Click="BtnDiscard_Click" Visibility="Collapsed" />
                
                <Button x:Name="BtnOk" Content="OK" Style="{StaticResource MaterialDesignRaisedButton}" Click="BtnOk_Click" Visibility="Collapsed" IsDefault="True" />
                <Button x:Name="BtnYes" Content="Yes" Style="{StaticResource MaterialDesignRaisedButton}" Click="BtnYes_Click" Visibility="Collapsed" IsDefault="True" />
                <Button x:Name="BtnSave" Content="Save" Style="{StaticResource MaterialDesignRaisedButton}" Click="BtnSave_Click" Visibility="Collapsed" IsDefault="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
