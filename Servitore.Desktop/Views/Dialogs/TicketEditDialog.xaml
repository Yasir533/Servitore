<Window x:Class="Servitore.Desktop.Views.Dialogs.TicketEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Service Ticket Details" Height="620" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Loaded="Window_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Edit Service Ticket" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" x:Name="TitleText"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                
                <ComboBox x:Name="CustomerCombo"
                          materialDesign:HintAssist.Hint="Customer *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="CustomerName"
                          SelectedValuePath="CustomerId"
                          SelectionChanged="CustomerCombo_SelectionChanged"
                          Margin="0,0,0,12" />

                <ComboBox x:Name="AssetCombo"
                          materialDesign:HintAssist.Hint="Asset Product *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="ProductName"
                          SelectedValuePath="AssetId"
                          Margin="0,0,0,12" />

                <TextBox x:Name="ProblemBox"
                         materialDesign:HintAssist.Hint="Problem Description *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,12" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <ComboBox Grid.Column="0" x:Name="PriorityCombo"
                              materialDesign:HintAssist.Hint="Priority *"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}">
                        <ComboBoxItem Content="Low" Tag="Low" />
                        <ComboBoxItem Content="Medium" Tag="Medium" IsSelected="True" />
                        <ComboBoxItem Content="High" Tag="High" />
                        <ComboBoxItem Content="Critical" Tag="Critical" />
                    </ComboBox>

                    <ComboBox Grid.Column="2" x:Name="StatusCombo"
                              materialDesign:HintAssist.Hint="Status *"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}">
                        <ComboBoxItem Content="Open" Tag="Open" IsSelected="True" />
                        <ComboBoxItem Content="In Progress" Tag="InProgress" />
                        <ComboBoxItem Content="On Hold" Tag="OnHold" />
                        <ComboBoxItem Content="Resolved" Tag="Resolved" />
                        <ComboBoxItem Content="Closed" Tag="Closed" />
                        <ComboBoxItem Content="Cancelled" Tag="Cancelled" />
                    </ComboBox>
                </Grid>

                <ComboBox x:Name="EngineerCombo"
                          materialDesign:HintAssist.Hint="Assign Engineer"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="Id"
                          Margin="0,0,0,12" />

                <TextBox x:Name="ResolutionBox"
                         materialDesign:HintAssist.Hint="Resolution Notes"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,12" />

                <!-- SLA Information Display -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="4" Padding="12" Margin="0,0,0,12" x:Name="SlaPanel" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="SLA Due Date:" FontWeight="Bold" FontSize="11" Opacity="0.6" />
                        <TextBlock x:Name="SlaDueText" FontSize="13" Margin="0,2,0,4" />
                        <TextBlock x:Name="SlaStatusText" FontSize="12" FontWeight="Bold" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button x:Name="SaveButton" Content="Save" Style="{StaticResource MaterialDesignRaisedButton}" Click="Save_Click" Width="90" />
        </StackPanel>
    </Grid>
</Window>
