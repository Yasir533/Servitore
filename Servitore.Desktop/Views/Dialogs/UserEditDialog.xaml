<Window x:Class="Servitore.Desktop.Views.Dialogs.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="User Details" Height="520" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Loaded="Window_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Edit User Details" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" x:Name="TitleText"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                <TextBox x:Name="FullNameBox"
                         materialDesign:HintAssist.Hint="Full Name *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <TextBox x:Name="UsernameBox"
                         materialDesign:HintAssist.Hint="Username *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <TextBox x:Name="EmailBox"
                         materialDesign:HintAssist.Hint="Email"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <TextBox x:Name="PhoneBox"
                         materialDesign:HintAssist.Hint="Phone Number"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12" />

                <ComboBox x:Name="RoleCombo"
                          materialDesign:HintAssist.Hint="System Role *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,12">
                    <ComboBoxItem Content="Admin" Tag="Admin" />
                    <ComboBoxItem Content="Manager" Tag="Manager" />
                    <ComboBoxItem Content="Engineer" Tag="Engineer" />
                    <ComboBoxItem Content="Operator" Tag="Operator" />
                </ComboBox>

                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Password (Leave blank to keep current)"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,0,12" />

                <CheckBox x:Name="IsActiveCheck"
                          Content="Account Active"
                          Style="{StaticResource MaterialDesignActionLightCheckBox}"
                          IsChecked="True" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button Content="Save" Style="{StaticResource MaterialDesignRaisedButton}" Click="Save_Click" Width="90" />
        </StackPanel>
    </Grid>
</Window>
