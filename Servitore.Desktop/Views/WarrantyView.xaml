<UserControl x:Class="Servitore.Desktop.Views.WarrantyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Warranty Management" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="Track asset warranty status" Opacity="0.55" FontSize="13" />
            </StackPanel>
            <Button Content="+ Add Warranty"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding AddWarrantyCommand}"
                    HorizontalAlignment="Right" Margin="16,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <ProgressBar Grid.Row="1" Style="{StaticResource MaterialDesignLinearProgressBar}"
                     IsIndeterminate="True" Margin="0,0,0,8"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- Summary chips -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Background="#FFCDD2" CornerRadius="16" Padding="14,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="#C62828" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Foreground="#C62828" VerticalAlignment="Center">
                        <Run Text="Expired: " /><Run Text="{Binding ExpiredCount}" FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Background="#FFF9C4" CornerRadius="16" Padding="14,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ClockAlert" Foreground="#F57F17" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Foreground="#F57F17" VerticalAlignment="Center">
                        <Run Text="Expiring in 30d: " /><Run Text="{Binding ExpiringCount}" FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Background="#C8E6C9" CornerRadius="16" Padding="14,6">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ShieldCheck" Foreground="#2E7D32" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Foreground="#2E7D32" VerticalAlignment="Center">
                        <Run Text="Active: " /><Run Text="{Binding ActiveCount}" FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <TextBox Grid.Row="3"
                 materialDesign:HintAssist.Hint="Search by asset or customer…"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12" />

        <Border Grid.Row="4" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6">
            <DataGrid ItemsSource="{Binding WarrantiesView}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True"
                      materialDesign:DataGridAssist.CellPadding="14 8 14 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="14 8 14 8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Asset"       Binding="{Binding AssetName}"      Width="*" />
                    <DataGridTextColumn Header="Customer"    Binding="{Binding CustomerName}"   Width="180" />
                    <DataGridTextColumn Header="Serial No."  Binding="{Binding SerialNumber}"   Width="140" />
                    <DataGridTextColumn Header="Start Date"  Binding="{Binding StartDate, StringFormat='{}{0:dd MMM yyyy}'}" Width="110" />
                    <DataGridTextColumn Header="End Date"    Binding="{Binding EndDate, StringFormat='{}{0:dd MMM yyyy}'}"   Width="110" />
                    <DataGridTextColumn Header="Days Left"   Binding="{Binding DaysRemaining}"  Width="90" />
                    <DataGridTextColumn Header="Status"      Binding="{Binding WarrantyStatus}" Width="100" />
                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.EditWarrantyCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" ToolTip="Edit">
                                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeleteWarrantyCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" ToolTip="Delete"
                                            Foreground="{DynamicResource MaterialDesignValidationErrorBrush}">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WarrantyStatus}" Value="Expired">
                                <Setter Property="Background" Value="#FFEBEE" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WarrantyStatus}" Value="Expiring Soon">
                                <Setter Property="Background" Value="#FFFDE7" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
