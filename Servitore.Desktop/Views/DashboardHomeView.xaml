<UserControl x:Class="Servitore.Desktop.Views.DashboardHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Page header -->
            <TextBlock Text="Dashboard" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Business overview at a glance" Opacity="0.55" FontSize="13" Margin="0,0,0,24" />

            <!-- Loading indicator -->
            <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                         IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Margin="0,0,0,16" />

            <!-- Summary cards row -->
            <UniformGrid Rows="1" Columns="5" Margin="0,0,0,24">

                <!-- Total Customers -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="6" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="AccountGroup" Width="28" Height="28"
                                                 Foreground="#5C6BC0" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Summary.TotalCustomers}"
                                   FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Total Customers" Opacity="0.6" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Total Assets -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="6" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Devices" Width="28" Height="28"
                                                 Foreground="#26A69A" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Summary.TotalAssets}"
                                   FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Total Assets" Opacity="0.6" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Open Tickets -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="6" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="TicketOutline" Width="28" Height="28"
                                                 Foreground="#EF5350" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Summary.OpenTickets}"
                                   FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Open Tickets" Opacity="0.6" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Expiring Warranties -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="6" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="ShieldAlert" Width="28" Height="28"
                                                 Foreground="#FFA726" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Summary.ExpiringWarranties}"
                                   FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Warranties Expiring (30d)" Opacity="0.6" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Active AMC Contracts -->
                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="6" Padding="20,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="FileSign" Width="28" Height="28"
                                                 Foreground="#42A5F5" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Summary.ExpiringAmcContracts}"
                                   FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="AMC Expiring (30d)" Opacity="0.6" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Row of Quick Actions and Resolved Stats -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Quick Actions -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <UniformGrid Rows="1" Columns="4">
                        <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                Command="{Binding AddCustomerCommand}" Margin="0,0,8,0" Height="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountPlus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Add Customer" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                Command="{Binding AddAssetCommand}" Margin="0,0,8,0" Height="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Laptop" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Add Asset" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                Command="{Binding CreateTicketCommand}" Margin="0,0,8,0" Height="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlusCircleOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="New Ticket" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                Command="{Binding CreateAmcCommand}" Height="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocument" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="New AMC" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>

                <!-- Resolved today card -->
                <Border Grid.Column="1" Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="6" Padding="20,14" MinWidth="220" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="24" Height="24"
                                                 Foreground="#66BB6A" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="{Binding Summary.TicketsResolvedToday}" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="Tickets Resolved Today" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main split columns: Recent Tickets (left) vs Expiry Alerts (right) -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Recent Tickets -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Recent Service Tickets" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Height="280">
                        <DataGrid ItemsSource="{Binding Summary.RecentTickets}" AutoGenerateColumns="False" IsReadOnly="True"
                                  materialDesign:DataGridAssist.CellPadding="12 6 12 6"
                                  materialDesign:DataGridAssist.ColumnHeaderPadding="12 6 12 6">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ticket #" Binding="{Binding TicketNumber}" Width="100" />
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                                <DataGridTextColumn Header="Asset Product" Binding="{Binding AssetName}" Width="120" />
                                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="80" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="95" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- Expiry Alerts Tabbed Card -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Expiry Alerts" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Height="280">
                        <TabControl>
                            <!-- AMC Alerts -->
                            <TabItem Header="AMC Expiring">
                                <DataGrid ItemsSource="{Binding Summary.AmcAlerts}" AutoGenerateColumns="False" IsReadOnly="True"
                                          materialDesign:DataGridAssist.CellPadding="8 4 8 4"
                                          materialDesign:DataGridAssist.ColumnHeaderPadding="8 4 8 4">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                                        <DataGridTextColumn Header="Product" Binding="{Binding AssetName}" Width="110" />
                                        <DataGridTextColumn Header="Days" Binding="{Binding DaysRemaining}" Width="55" Foreground="Red" FontWeight="SemiBold" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            
                            <!-- Warranty Alerts -->
                            <TabItem Header="Warranty Expiring">
                                <DataGrid ItemsSource="{Binding Summary.WarrantyAlerts}" AutoGenerateColumns="False" IsReadOnly="True"
                                          materialDesign:DataGridAssist.CellPadding="8 4 8 4"
                                          materialDesign:DataGridAssist.ColumnHeaderPadding="8 4 8 4">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                                        <DataGridTextColumn Header="Product" Binding="{Binding AssetName}" Width="110" />
                                        <DataGridTextColumn Header="Days" Binding="{Binding DaysRemaining}" Width="55" Foreground="DarkOrange" FontWeight="SemiBold" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Bottom: Status Counts and Notifications -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <!-- Ticket Status Counts (Summary bar/canvas display) -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Ticket Status Summary" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Padding="20" Height="220">
                        <StackPanel VerticalAlignment="Center">
                            <!-- Open Tickets Bar -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <TextBlock Text="Open / In Progress" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="{Binding Summary.OpenTickets}" HorizontalAlignment="Right" FontSize="12" />
                                </Grid>
                                <ProgressBar Value="{Binding Summary.OpenTickets}" Maximum="50" Height="8" Margin="0,4,0,0" Foreground="#E53935" />
                            </StackPanel>

                            <!-- Resolved Today Bar -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <TextBlock Text="Resolved Today" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="{Binding Summary.TicketsResolvedToday}" HorizontalAlignment="Right" FontSize="12" />
                                </Grid>
                                <ProgressBar Value="{Binding Summary.TicketsResolvedToday}" Maximum="50" Height="8" Margin="0,4,0,0" Foreground="#4CAF50" />
                            </StackPanel>

                            <!-- Total Revenue Stats -->
                            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,12,0,0">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Total AMC Revenue" Opacity="0.55" FontSize="11" />
                                        <TextBlock Text="{Binding Summary.TotalAmcRevenue, StringFormat='{}{0:₹0,0}'}" FontSize="18" FontWeight="Bold" Foreground="#3F51B5" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Recent Notifications -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Recent Notifications" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Padding="4" Height="220">
                        <Grid>
                            <!-- Empty state when no notifications -->
                            <TextBlock Text="No recent notifications."
                                       Opacity="0.45" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding HasNoNotifications, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding HasNoNotifications, Converter={StaticResource InverseBooleanConverter}}">
                                <ItemsControl ItemsSource="{Binding Summary.RecentNotifications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                    BorderThickness="0,0,0,1" Padding="16,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding CreatedDate, StringFormat='{}{0:dd MMM HH:mm}'}"
                                                               Opacity="0.5" FontSize="11" VerticalAlignment="Center" Margin="16,0,0,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
