<UserControl x:Class="Servitore.Desktop.Views.DashboardHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
 
     <ScrollViewer VerticalScrollBarVisibility="Auto">
         <StackPanel Margin="24">
 
             <!-- Page header -->
             <TextBlock Text="Dashboard" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,4" />
             <TextBlock Text="Business overview at a glance" Opacity="0.55" FontSize="13" Margin="0,0,0,24" />
 
             <!-- Loading indicator -->
             <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                          IsIndeterminate="True"
                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Margin="0,0,0,16" />
 
             <!-- Summary cards row -->
             <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">
 
                 <!-- Total Customers -->
                 <Border Background="{DynamicResource MaterialDesignCardBackground}"
                         CornerRadius="6" Margin="0,0,12,0" Padding="20,18">
                     <StackPanel>
                         <materialDesign:PackIcon Kind="AccountGroup" Width="28" Height="28"
                                                  Foreground="#5C6BC0" Margin="0,0,0,8" />
                         <TextBlock Text="{Binding Summary.TotalCustomers}"
                                    FontSize="32" FontWeight="Bold" />
                         <TextBlock Text="Total Customers" Opacity="0.6" FontSize="13.5" Margin="0,4,0,0" />
                     </StackPanel>
                 </Border>
 
                 <!-- Total Products -->
                 <Border Background="{DynamicResource MaterialDesignCardBackground}"
                         CornerRadius="6" Margin="0,0,12,0" Padding="20,18">
                     <StackPanel>
                         <materialDesign:PackIcon Kind="Devices" Width="28" Height="28"
                                                  Foreground="#26A69A" Margin="0,0,0,8" />
                         <TextBlock Text="{Binding Summary.TotalProducts}"
                                    FontSize="32" FontWeight="Bold" />
                         <TextBlock Text="Total Products" Opacity="0.6" FontSize="13.5" Margin="0,4,0,0" />
                     </StackPanel>
                 </Border>
 
                 <!-- Today's Service Entries -->
                 <Border Background="{DynamicResource MaterialDesignCardBackground}"
                         CornerRadius="6" Margin="0,0,12,0" Padding="20,18">
                     <StackPanel>
                         <materialDesign:PackIcon Kind="TicketOutline" Width="28" Height="28"
                                                  Foreground="#EF5350" Margin="0,0,0,8" />
                         <TextBlock Text="{Binding Summary.TodayServiceEntries}"
                                    FontSize="32" FontWeight="Bold" />
                         <TextBlock Text="Today's Service Entries" Opacity="0.6" FontSize="13.5" Margin="0,4,0,0" />
                     </StackPanel>
                 </Border>
 
                 <!-- Online Users -->
                 <Border Background="{DynamicResource MaterialDesignCardBackground}"
                         CornerRadius="6" Padding="20,18">
                     <StackPanel>
                         <materialDesign:PackIcon Kind="AccountMultiple" Width="28" Height="28"
                                                  Foreground="#42A5F5" Margin="0,0,0,8" />
                         <TextBlock Text="{Binding Summary.OnlineUsers}"
                                    FontSize="32" FontWeight="Bold" />
                         <TextBlock Text="Online Users" Opacity="0.6" FontSize="13.5" Margin="0,4,0,0" />
                     </StackPanel>
                 </Border>
 
             </UniformGrid>
 
             <!-- Row of Quick Actions -->
             <StackPanel Margin="0,0,0,24">
                 <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                 <UniformGrid Rows="1" Columns="4">
                     <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                             Command="{Binding AddCustomerCommand}" Margin="0,0,8,0" Height="48">
                         <StackPanel Orientation="Horizontal">
                             <materialDesign:PackIcon Kind="AccountPlus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                             <TextBlock Text="Add Customer" VerticalAlignment="Center" />
                         </StackPanel>
                     </Button>
                     <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                             Command="{Binding AddProductCommand}" Margin="0,0,8,0" Height="48">
                         <StackPanel Orientation="Horizontal">
                             <materialDesign:PackIcon Kind="Laptop" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                             <TextBlock Text="Add Product" VerticalAlignment="Center" />
                         </StackPanel>
                     </Button>
                     <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                             Command="{Binding CreateServiceEntryCommand}" Margin="0,0,8,0" Height="48">
                         <StackPanel Orientation="Horizontal">
                             <materialDesign:PackIcon Kind="PlusCircleOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                             <TextBlock Text="New Service Entry" VerticalAlignment="Center" />
                         </StackPanel>
                     </Button>
                     <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                             Command="{Binding ViewActivityLogsCommand}" Height="48">
                         <StackPanel Orientation="Horizontal">
                             <materialDesign:PackIcon Kind="FormatListBulleted" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                             <TextBlock Text="View Activity Logs" VerticalAlignment="Center" />
                         </StackPanel>
                     </Button>
                 </UniformGrid>
             </StackPanel>
 
             <!-- Main split columns: Recent Service Entries (left) vs Live Activity Feed (right) -->
             <Grid Margin="0,0,0,10">
                 <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="3*" />
                     <ColumnDefinition Width="24" />
                     <ColumnDefinition Width="2*" />
                 </Grid.ColumnDefinitions>
 
                 <!-- Recent Service Entries -->
                 <StackPanel Grid.Column="0">
                     <TextBlock Text="Recent Service Entries" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                     <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Height="300">
                         <DataGrid ItemsSource="{Binding Summary.RecentServiceEntries}" AutoGenerateColumns="False" IsReadOnly="True"
                                   FontSize="14" RowHeight="44"
                                   materialDesign:DataGridAssist.CellPadding="16 10 16 10"
                                   materialDesign:DataGridAssist.ColumnHeaderPadding="16 10 16 10">
                             <DataGrid.Columns>
                                 <DataGridTextColumn Header="Entry #" Binding="{Binding ServiceEntryNumber}" Width="110" />
                                 <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                                 <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="150" />
                                 <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="90" />
                                 <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                             </DataGrid.Columns>
                         </DataGrid>
                     </Border>
                 </StackPanel>
 
                 <!-- Live Activity Feed -->
                 <StackPanel Grid.Column="2">
                     <TextBlock Text="Live Activity Feed" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                     <Border Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6" Padding="4" Height="300">
                         <Grid>
                             <!-- Empty state when no activities -->
                             <TextBlock Text="No recent activities."
                                        Opacity="0.45" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding HasNoActivities, Converter={StaticResource BooleanToVisibilityConverter}}" />
 
                             <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding HasNoActivities, Converter={StaticResource InverseBooleanConverter}}">
                                 <ItemsControl ItemsSource="{Binding Summary.RecentActivities}">
                                     <ItemsControl.ItemTemplate>
                                         <DataTemplate>
                                             <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                     BorderThickness="0,0,0,1" Padding="12,10">
                                                 <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
 
                                                     <materialDesign:PackIcon Kind="FlashOutline" Foreground="#FFB300" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0" />
 
                                                     <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                         <TextBlock FontSize="13.5" TextWrapping="Wrap">
                                                             <Run Text="{Binding UserName, Mode=OneWay}" FontWeight="SemiBold" />
                                                             <Run Text=" " />
                                                             <Run Text="{Binding Action, Mode=OneWay}" />
                                                         </TextBlock>
                                                         <TextBlock Text="{Binding Module}" FontSize="11" Opacity="0.55" Margin="0,2,0,0" />
                                                     </StackPanel>
 
                                                     <TextBlock Grid.Column="2" Text="{Binding DateTime, StringFormat='{}{0:HH:mm:ss}'}"
                                                                Opacity="0.5" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                 </Grid>
                                             </Border>
                                         </DataTemplate>
                                     </ItemsControl.ItemTemplate>
                                 </ItemsControl>
                             </ScrollViewer>
                         </Grid>
                     </Border>
                 </StackPanel>
             </Grid>
 
         </StackPanel>
     </ScrollViewer>
 </UserControl>
