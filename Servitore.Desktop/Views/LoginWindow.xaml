<Window x:Class="Servitore.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Servitore - Login" Height="540" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/Icons/logo.ico"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center">

            <!-- Logo Image -->
            <Image Source="pack://application:,,,/Assets/Images/logo.png"
                   Height="80" Width="80"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"
                   Stretch="Uniform" />

            <!-- Logo / Title -->
            <TextBlock Text="Servitore" FontSize="34" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4" />
            <TextBlock Text="Service Management System" FontSize="13" Opacity="0.6"
                       HorizontalAlignment="Center" Margin="0,0,0,30" />

            <!-- Login Form Panel (Visible by default) -->
            <StackPanel x:Name="LoginFormPanel" Visibility="Visible">
                <!-- Username -->
                <TextBox x:Name="UsernameBox"
                         materialDesign:HintAssist.Hint="Username"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

                <!-- Password (Enter key triggers login) -->
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Password"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             KeyDown="PasswordBox_KeyDown"
                             Margin="0,0,0,8"
                             IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

                <!-- Error message -->
                <TextBlock x:Name="ErrorText"
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,8"
                           Visibility="Collapsed" />

                <!-- Login button with progress indicator -->
                <Button Content="LOG IN"
                        Click="LoginButton_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,16,0,0"
                        Height="44"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

                <!-- Busy spinner -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             HorizontalAlignment="Center"
                             Margin="0,16,0,0"
                             Height="28" Width="28"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>

            <!-- Elegant status light -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,32,0,0">
                <Ellipse x:Name="StatusLight" Width="10" Height="10" Fill="#FFB300" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock x:Name="StatusText" Text="Connecting to server..." FontSize="12.5" Opacity="0.75" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
