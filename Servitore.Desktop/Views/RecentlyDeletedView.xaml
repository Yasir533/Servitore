<UserControl x:Class="Servitore.Desktop.Views.RecentlyDeletedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Recently Deleted" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="Restore soft-deleted records or delete them permanently before they expire" Opacity="0.55" FontSize="13" />
        </StackPanel>

        <!-- Loading Progress Bar -->
        <ProgressBar Grid.Row="1" Style="{StaticResource MaterialDesignLinearProgressBar}"
                     IsIndeterminate="True" Margin="0,0,0,8"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- Search Bar -->
        <TextBox Grid.Row="2"
                 materialDesign:HintAssist.Hint="Search recently deleted by name, type, or username…"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12" />

        <!-- Data Grid -->
        <Border Grid.Row="3" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6">
            <DataGrid ItemsSource="{Binding ItemsView}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True"
                      FontSize="14" RowHeight="44"
                      materialDesign:DataGridAssist.CellPadding="16 10 16 10"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="16 10 16 10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type"            Binding="{Binding Type}"          Width="120" FontWeight="Medium" />
                    <DataGridTextColumn Header="Record Name"     Binding="{Binding Name}"          Width="*" />
                    <DataGridTextColumn Header="Deleted By"      Binding="{Binding DeletedBy}"     Width="150" />
                    <DataGridTextColumn Header="Deleted Date"    Binding="{Binding DeletedDate, StringFormat='{}{0:dd MMM yyyy HH:mm}'}" Width="160" />
                    
                    <DataGridTemplateColumn Header="Days Remaining" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ClockOutline" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#FF9800" />
                                    <TextBlock Text="{Binding DaysRemaining, StringFormat='{}{0} Days'}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#FF9800" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.RestoreCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Width="32" Height="32" Padding="0" Margin="4,0"
                                            ToolTip="Restore">
                                        <materialDesign:PackIcon Kind="BackupRestore" Width="16" Height="16" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeletePermanentCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Width="32" Height="32" Padding="0" Margin="4,0"
                                            ToolTip="Delete Permanently"
                                            Foreground="{DynamicResource MaterialDesignValidationErrorBrush}">
                                        <materialDesign:PackIcon Kind="DeleteForever" Width="16" Height="16" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
